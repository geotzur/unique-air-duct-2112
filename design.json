{
  "colors": {
    "primary": "#B41FCF",
    "primary_light": "#F3E3F6",
    "primary_dark": "#63176F",
    "secondary": "#35C451",
    "accent": "#FFCF2A",
    "background": "#FDF9F5",
    "surface": "#F6EDF7",
    "surface_dark": "#1D0B24",
    "text_primary": "#1B0920",
    "text_secondary": "#5A4861",
    "text_light": "#9E8AA5",
    "border": "#E7D9E9"
  },
  "fonts": {
    "heading": "'Barlow Condensed', 'Arial Narrow', system-ui, sans-serif",
    "body": "'Nunito', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif",
    "google_import": "https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800;900&family=Nunito:wght@400;500;600;700;800&display=swap"
  },
  "gradients": {
    "hero_overlay": "linear-gradient(135deg, #B41FCF 0%, #63176F 55%, #1D0B24 100%)",
    "card_overlay": "linear-gradient(180deg, rgba(29,11,36,0) 40%, rgba(29,11,36,0.72) 100%)",
    "cta_overlay": "linear-gradient(160deg, #63176F 0%, #B41FCF 60%, #1D0B24 100%)",
    "section_bg": "radial-gradient(circle at 15% 20%, rgba(180,31,207,0.22) 0%, transparent 42%), radial-gradient(circle at 85% 80%, rgba(99,23,111,0.38) 0%, transparent 50%), radial-gradient(circle at 55% 55%, rgba(53,196,81,0.14) 0%, transparent 45%), #1D0B24",
    "gradient_blob_1": "radial-gradient(circle, rgba(180,31,207,0.55) 0%, rgba(180,31,207,0) 70%)",
    "gradient_blob_2": "radial-gradient(circle, rgba(53,196,81,0.42) 0%, rgba(53,196,81,0) 70%)"
  },
  "style": {
    "border_radius": "12px",
    "border_radius_lg": "20px",
    "border_radius_xl": "28px",
    "border_radius_full": "50px",
    "shadow_sm": "0 2px 8px rgba(29,11,36,0.06)",
    "shadow_md": "0 8px 24px rgba(29,11,36,0.10)",
    "shadow_lg": "0 12px 32px rgba(180,31,207,0.18)",
    "shadow_xl": "0 24px 56px rgba(29,11,36,0.24)"
  },
  "glass": {
    "card_dark": "background: rgba(29,11,36,0.72); backdrop-filter: blur(14px); border: 1px solid rgba(253,249,245,0.08);",
    "card_light": "background: rgba(253,249,245,0.88); backdrop-filter: blur(16px); border: 1px solid rgba(180,31,207,0.18);",
    "input": "background: rgba(253,249,245,0.94); backdrop-filter: blur(8px); border: 1px solid #E7D9E9;"
  },
  "animations": {
    "float_slow": "float-slow 30s ease-in-out infinite",
    "ken_burns": "ken-burns 18s ease-in-out infinite alternate",
    "cta_pulse": "cta-pulse 2.4s cubic-bezier(0.34, 1.56, 0.64, 1) infinite"
  },
  "rtl": false
}
